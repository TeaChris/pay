# Application
NODE_ENV=development
PORT=3000
APP_NAME=pay-auth
APP_URL=http://localhost:3000
TRUSTED_PROXIES=loopback

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pay_auth?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Keys (ES256) — generate with: npm run generate-keys
JWT_PRIVATE_KEY_PATH=./keys/ec-private.pem
JWT_PUBLIC_KEY_PATH=./keys/ec-public.pem
JWT_ISSUER=pay-auth
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# Cookies
COOKIE_SECURE=false

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# CORS
CORS_ORIGINS=http://localhost:5173

# MFA
MFA_ISSUER=PayApp
# Generate with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Logging
LOG_LEVEL=debug

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com