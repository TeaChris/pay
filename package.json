{
  "name": "pay-auth",
  "version": "1.0.0",
  "description": "Production-grade fintech authentication and identity platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "generate-keys": "tsx --env-file=.env scripts/generate-keys.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.78.1",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.12.0",
    "ioredis": "^5.4.0",
    "jose": "^6.0.0",
    "otpauth": "^9.4.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
